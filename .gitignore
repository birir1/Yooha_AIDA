# .gitignore
# ============================================================
# OS / System files
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
env/
.venv/
ENV/

# Jupyter / notebooks checkpoints
.ipynb_checkpoints/

# Python logs
*.log

# ============================================================
# Jupyter Notebooks (optional: uncomment if you DON'T want to version notebooks)
# notebooks/*.ipynb

# ============================================================
# Node.js (VERY IMPORTANT for your case)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
out/

# ============================================================
# Frontend / bundlers (if used later)
# ============================================================
.next/
.nuxt/
.svelte-kit/

# ============================================================
# ML / AI artifacts (VERY IMPORTANT for your repo)
# ============================================================
*.pt
*.pth
*.bin
*.onnx
*.ckpt
*.h5
*.pickle
*.pkl

# embeddings / vector DBs
*.faiss
*.index
*.npy
*.npz

# model caches
.cache/
models/
checkpoints/

# ============================================================
# Data (you have notebooks + retrieval system)
# ============================================================
data/
datasets/
*.csv
*.parquet
*.jsonl

# ============================================================
# Logs & runtime files
# ============================================================
logs/
*.log
*.pid
*.seed

# ============================================================
# Environment variables
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# IDE / editors
# ============================================================
.vscode/
.idea/
*.swp

# ============================================================
# Temporary / misc
# ============================================================
tmp/
temp/